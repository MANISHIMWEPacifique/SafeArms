# SafeArms Backend Environment Configuration
# Copy this to .env and fill in your values

# Option 1: Use DATABASE_URL (recommended for cloud providers)
# DATABASE_URL=postgresql://username:password@host:5432/database_name

# Option 2: Use individual parameters (for local PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=safearms
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-change-this

# Email configuration (for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=SafeArms System
SMTP_FROM_EMAIL=your-email@gmail.com

# Security: never enable this in production.
# When true (non-production only), OTP values are printed to the console
# if email delivery is unavailable or using non-routable demo accounts.
ALLOW_INSECURE_OTP_CONSOLE_FALLBACK=true

# Server port
PORT=3000

# Database timezone (used for CURRENT_TIMESTAMP consistency with ML features)
# Set to your local timezone e.g. Africa/Johannesburg, UTC, etc.
DB_TIMEZONE=Africa/Johannesburg
