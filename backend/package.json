{
  "name": "safearms-backend",
  "version": "1.0.0",
  "description": "SafeArms Backend API - Police Firearm Control and Investigation Support Platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "deploy:smoke": "node src/scripts/deploySmokeCheck.js",
    "seed": "node src/scripts/seedDatabase.js",
    "seed:training": "node src/scripts/runTrainingWorkflowSeed.js all",
    "seed:training:baseline": "node src/scripts/runTrainingWorkflowSeed.js baseline",
    "seed:training:anomalies": "node src/scripts/runTrainingWorkflowSeed.js anomalies",
    "seed:training:validate": "node src/scripts/runTrainingWorkflowSeed.js validate",
    "seed:training:detect": "node src/scripts/detectSeededAnomalies.js",
    "seed:training:generate": "node src/scripts/generateTrainingData.js all",
    "seed:training:generate:baseline": "node src/scripts/generateTrainingData.js baseline",
    "seed:training:generate:anomalies": "node src/scripts/generateTrainingData.js anomalies",
    "mobile:seed-demo": "node src/scripts/setupOfficerMobileDemo.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "firearm-management",
    "police",
    "investigation",
    "ml-anomaly-detection"
  ],
  "author": "SafeArms Development Team",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "ml-kmeans": "^6.0.0",
    "multer": "^2.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "pg": "^8.11.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
